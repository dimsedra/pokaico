# =============================================================================
# Pokaico — Environment Variables Template
# Copy this file to .env and fill in your keys. Never commit .env!
# =============================================================================

# -----------------------------------------------------------------------------
# Option A: OpenCode Go (recommended — single key for all models, no rate limit)
# Get your key at: https://opencode.ai  (requires OpenCode Go subscription)
# Provider ID: opencode-go
# -----------------------------------------------------------------------------
OPENCODE_API_KEY=

# Default model when using OpenCode Go. Available options:
#   kimi-k2.5         → Kimi K2.5       (fast, great for chat)
#   kimi-k2.6         → Kimi K2.6       (newer, slightly better)
#   kimi-k2.7-code    → Kimi K2.7 Code  (code-focused)
#   deepseek-v4-flash → DeepSeek V4 Flash (fastest, lightweight)
#   deepseek-v4-pro   → DeepSeek V4 Pro  (smarter, slower)
#   qwen3.7-plus      → Qwen3.7 Plus     (balanced)
#   qwen3.7-max       → Qwen3.7 Max      (high quality)
#   minimax-m3        → MiniMax-M3       (multimodal capable)
#
# Format: opencode-go/<model-id>
# Example: TEST_MODEL=opencode-go/kimi-k2.5
TEST_MODEL=opencode-go/kimi-k2.5

# -----------------------------------------------------------------------------
# Option B: Google Gemini (free tier, but has rate limits)
# Get your key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=

# Uncomment below to use Gemini instead:
# TEST_MODEL=google/gemini-2.0-flash-lite
